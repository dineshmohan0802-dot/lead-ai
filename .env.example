# ── Supabase ───────────────────────────────────────────────────
VITE_SUPABASE_URL=        # Supabase project URL (e.g. https://your-project.supabase.co)
VITE_SUPABASE_ANON_KEY=   # Supabase anonymous key (public, safe for frontend)
SUPABASE_SERVICE_KEY=     # Supabase service role key (secret, backend only)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # PostgreSQL connection string (postgres://user:pass@host:port/db)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_USER_ID=            # UUID of the app creator; this user gets role "admin" on first login
